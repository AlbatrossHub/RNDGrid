<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_upi_qr" model="ir.ui.view">
        <field name="name">res.company.form.inherit.upi.qr</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="UPI &amp; Bank Configuration" name="upi_bank_config">
                    <group>
                        <group string="UPI Settings">
                            <field name="upi_id" placeholder="e.g. yourname@bank"/>
                            <field name="upi_payee_name" placeholder="Leave empty to use Company Name"/>
                        </group>
                        <group string="Bank Details">
                            <field name="upi_account_number"/>
                            <field name="upi_bank_name"/>
                            <field name="upi_ifsc"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
