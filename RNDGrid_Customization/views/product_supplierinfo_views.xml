<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_supplierinfo_form_view_inherit_rndgrid" model="ir.ui.view">
        <field name="name">product.supplierinfo.form.view.inherit.rndgrid</field>
        <field name="model">product.supplierinfo</field>
        <field name="inherit_id" ref="product.product_supplierinfo_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='price']" position="after">
                <field name="price_student"/>
                <field name="price_startup"/>
                <field name="price_industry"/>
            </xpath>
        </field>
    </record>

    <record id="product_supplierinfo_tree_view_inherit_rndgrid" model="ir.ui.view">
        <field name="name">product.supplierinfo.tree.view.inherit.rndgrid</field>
        <field name="model">product.supplierinfo</field>
        <field name="inherit_id" ref="product.product_supplierinfo_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='price']" position="after">
                <field name="price_student"/>
                <field name="price_startup"/>
                <field name="price_industry"/>
            </xpath>
        </field>
    </record>
</odoo>
