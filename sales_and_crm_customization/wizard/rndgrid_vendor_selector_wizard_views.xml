<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View for Vendor Selector Wizard -->
    <record id="view_rndgrid_vendor_selector_wizard_form" model="ir.ui.view">
        <field name="name">rndgrid.vendor.selector.wizard.form</field>
        <field name="model">rndgrid.vendor.selector.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Lab Vendor">
                <sheet>
                    <group>
                        <field name="product_tmpl_id" readonly="1" options="{'no_open': True}"/>
                    </group>
                    <field name="vendor_line_ids">
                        <list editable="bottom" create="false" delete="false">
                            <field name="partner_id" readonly="1" options="{'no_open': True}"/>
                            <field name="price_student" readonly="1"/>
                            <field name="price_startup" readonly="1"/>
                            <field name="price_industry" readonly="1"/>
                            <button name="action_select_vendor" type="object" string="Select" class="btn-primary" icon="fa-check"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
