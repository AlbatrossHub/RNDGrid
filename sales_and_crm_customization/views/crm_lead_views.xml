<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_view_form_inherit_rndgrid" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.rndgrid</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="before">
                    <group>
                        <group string="Material Information">
                            <field name="rndgrid_material_name"/>
                            <field name="rndgrid_sample_type"/>
                            <field name="rndgrid_is_hazardous"/>
                        </group>
                    </group>
                    <separator string="Tests Needed"/>
                    <field name="rndgrid_test_line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="instrument_id"/>
                            <field name="test_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        </list>
                    </field>
            </xpath>
        </field>
    </record>

    <!-- CRM Kanban View -->
    <record id="crm_case_kanban_view_leads_inherit_rndgrid" model="ir.ui.view">
        <field name="name">crm.lead.kanban.inherit.rndgrid</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_kanban_content')]//div[hasclass('o_kanban_record_bottom')]" position="before">
                <div class="o_kanban_record_subtitle" invisible="not rndgrid_segment">
                    <span class="badge rounded-pill text-bg-info">
                        <field name="rndgrid_segment"/>
                    </span>
                </div>
            </xpath>
        </field>
    </record>

    <!-- CRM List View (Opportunities) -->
    <record id="crm_case_tree_view_oppor_inherit_rndgrid" model="ir.ui.view">
        <field name="name">crm.lead.tree.inherit.rndgrid</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="rndgrid_segment" optional="show"/>
            </field>
        </field>
    </record>
</odoo>
